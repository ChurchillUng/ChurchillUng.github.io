<svg viewBox="0 0 1600 1000" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad3" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f0f9ff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e0f2fe;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1600" height="1000" fill="url(#bgGrad3)"/>
  
  <!-- Title -->
  <text x="800" y="80" font-family="Inter, sans-serif" font-size="48" font-weight="700" fill="#0f172a" text-anchor="middle">Parametric Drone Frame</text>
  
  <!-- Drone frame (top view) -->
  <g transform="translate(800, 500)">
    <!-- Center body -->
    <rect x="-60" y="-40" width="120" height="80" fill="#0284c7" rx="8"/>
    
    <!-- Motors and arms -->
    <!-- Front right -->
    <line x1="60" y1="-40" x2="180" y2="-120" stroke="#38bdf8" stroke-width="12" stroke-linecap="round"/>
    <circle cx="180" cy="-120" r="25" fill="#0ea5e9"/>
    <circle cx="180" cy="-120" r="15" fill="#f0f9ff"/>
    
    <!-- Front left -->
    <line x1="-60" y1="-40" x2="-180" y2="-120" stroke="#38bdf8" stroke-width="12" stroke-linecap="round"/>
    <circle cx="-180" cy="-120" r="25" fill="#0ea5e9"/>
    <circle cx="-180" cy="-120" r="15" fill="#f0f9ff"/>
    
    <!-- Rear right -->
    <line x1="60" y1="40" x2="180" y2="120" stroke="#38bdf8" stroke-width="12" stroke-linecap="round"/>
    <circle cx="180" cy="120" r="25" fill="#0ea5e9"/>
    <circle cx="180" cy="120" r="15" fill="#f0f9ff"/>
    
    <!-- Rear left -->
    <line x1="-60" y1="40" x2="-180" y2="120" stroke="#38bdf8" stroke-width="12" stroke-linecap="round"/>
    <circle cx="-180" cy="120" r="25" fill="#0ea5e9"/>
    <circle cx="-180" cy="120" r="15" fill="#f0f9ff"/>
    
    <!-- Center compass -->
    <circle cx="0" cy="0" r="30" fill="none" stroke="#0284c7" stroke-width="3"/>
    <line x1="0" y1="-30" x2="0" y2="-45" stroke="#0284c7" stroke-width="3"/>
  </g>
  
  <!-- Info boxes -->
  <g font-family="Inter, sans-serif" font-size="32" fill="#475569">
    <text x="200" y="950">Script-Driven SolidWorks | Parametric | 3D Printed</text>
  </g>
</svg>
