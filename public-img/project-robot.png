<svg viewBox="0 0 1600 1000" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f0f9ff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e0f2fe;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1600" height="1000" fill="url(#bgGrad2)"/>
  
  <!-- Title -->
  <text x="800" y="80" font-family="Inter, sans-serif" font-size="48" font-weight="700" fill="#0f172a" text-anchor="middle">Robotic Arm Trajectory Controller</text>
  
  <!-- Robotic arm -->
  <g transform="translate(800, 480)">
    <!-- Base -->
    <circle cx="0" cy="120" r="35" fill="#0284c7"/>
    
    <!-- Joint 1 -->
    <line x1="0" y1="120" x2="0" y2="20" stroke="#0284c7" stroke-width="16" stroke-linecap="round"/>
    <circle cx="0" cy="20" r="25" fill="#0284c7"/>
    
    <!-- Segment 1 to Joint 2 -->
    <line x1="0" y1="20" x2="100" y2="-60" stroke="#38bdf8" stroke-width="14" stroke-linecap="round"/>
    <circle cx="100" cy="-60" r="22" fill="#0284c7"/>
    
    <!-- Segment 2 to Joint 3 -->
    <line x1="100" y1="-60" x2="180" y2="-120" stroke="#0284c7" stroke-width="14" stroke-linecap="round"/>
    <circle cx="180" cy="-120" r="22" fill="#0284c7"/>
    
    <!-- End effector -->
    <line x1="180" y1="-120" x2="240" y2="-160" stroke="#38bdf8" stroke-width="12" stroke-linecap="round"/>
    <circle cx="240" cy="-160" r="18" fill="#0ea5e9"/>
    
    <!-- Motion path indicator -->
    <path d="M 240 -160 Q 280 -140 300 -80" stroke="#ea580c" stroke-width="4" fill="none" stroke-dasharray="8,8"/>
  </g>
  
  <!-- Info boxes -->
  <g font-family="Inter, sans-serif" font-size="32" fill="#475569">
    <text x="200" y="950">6-Axis | Inverse Kinematics | Embedded Control</text>
  </g>
</svg>
