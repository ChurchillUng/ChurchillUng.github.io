<svg viewBox="0 0 1600 1000" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad4" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f0f9ff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e0f2fe;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="tempGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#f59e0b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ef4444;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1600" height="1000" fill="url(#bgGrad4)"/>
  
  <!-- Title -->
  <text x="800" y="80" font-family="Inter, sans-serif" font-size="48" font-weight="700" fill="#0f172a" text-anchor="middle">Compact Heat Exchanger Study</text>
  
  <!-- Heat exchanger visualization -->
  <g transform="translate(800, 500)">
    <!-- Main body -->
    <rect x="-150" y="-80" width="300" height="160" fill="none" stroke="#0284c7" stroke-width="8" rx="10"/>
    
    <!-- Fins (side view) -->
    <line x1="-140" y1="-50" x2="-140" y2="50" stroke="#38bdf8" stroke-width="4"/>
    <line x1="-100" y1="-70" x2="-100" y2="70" stroke="#38bdf8" stroke-width="4"/>
    <line x1="-60" y1="-75" x2="-60" y2="75" stroke="#38bdf8" stroke-width="4"/>
    <line x1="-20" y1="-75" x2="-20" y2="75" stroke="#38bdf8" stroke-width="4"/>
    <line x1="20" y1="-75" x2="20" y2="75" stroke="#38bdf8" stroke-width="4"/>
    <line x1="60" y1="-75" x2="60" y2="75" stroke="#38bdf8" stroke-width="4"/>
    <line x1="100" y1="-70" x2="100" y2="70" stroke="#38bdf8" stroke-width="4"/>
    <line x1="140" y1="-50" x2="140" y2="50" stroke="#38bdf8" stroke-width="4"/>
    
    <!-- Hot inlet -->
    <circle cx="-160" cy="-40" r="20" fill="#ef4444"/>
    <text x="-160" y="-25" text-anchor="middle" font-size="20" fill="white" font-weight="600">H</text>
    
    <!-- Cold outlet -->
    <circle cx="160" cy="40" r="20" fill="#3b82f6"/>
    <text x="160" y="55" text-anchor="middle" font-size="20" fill="white" font-weight="600">C</text>
    
    <!-- Temperature scale -->
    <rect x="-200" y="120" width="400" height="30" fill="url(#tempGrad)" rx="5"/>
  </g>
  
  <!-- Info boxes -->
  <g font-family="Inter, sans-serif" font-size="32" fill="#475569">
    <text x="200" y="950">Finned Aluminum | Thermal Analysis | Python Sweep</text>
  </g>
</svg>
