<svg viewBox="0 0 1600 1000" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f0f9ff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e0f2fe;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1600" height="1000" fill="url(#bgGrad)"/>
  
  <!-- Title -->
  <text x="800" y="80" font-family="Inter, sans-serif" font-size="48" font-weight="700" fill="#0f172a" text-anchor="middle">Aerospace Bracket Topology</text>
  
  <!-- 3D bracket shape simplified -->
  <g transform="translate(800, 500)">
    <!-- Main bracket outline -->
    <path d="M -200 -150 L 200 -150 L 200 -50 L 100 -50 L 100 150 L -100 150 L -100 -50 L -200 -50 Z" 
          fill="none" stroke="#0284c7" stroke-width="8" stroke-linejoin="round"/>
    
    <!-- Mounting holes -->
    <circle cx="-80" cy="-100" r="20" fill="none" stroke="#0284c7" stroke-width="6"/>
    <circle cx="80" cy="-100" r="20" fill="none" stroke="#0284c7" stroke-width="6"/>
    <circle cx="-80" cy="100" r="20" fill="none" stroke="#0284c7" stroke-width="6"/>
    <circle cx="80" cy="100" r="20" fill="none" stroke="#0284c7" stroke-width="6"/>
    
    <!-- Stress visualization -->
    <ellipse cx="0" cy="0" rx="120" ry="80" fill="#38bdf8" opacity="0.15"/>
    
    <!-- Load indicator -->
    <path d="M 0 -180 L 0 -220" stroke="#ea580c" stroke-width="6" marker-end="url(#arrowRed)"/>
  </g>
  
  <!-- Info boxes -->
  <g font-family="Inter, sans-serif" font-size="32" fill="#475569">
    <text x="200" y="950">Titanium | Topology Optimized | FEA Validated</text>
  </g>
  
  <defs>
    <marker id="arrowRed" markerWidth="10" markerHeight="10" refX="5" refY="5" orient="auto">
      <polygon points="0,0 10,5 0,10" fill="#ea580c"/>
    </marker>
  </defs>
</svg>
