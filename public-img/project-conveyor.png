<svg viewBox="0 0 1600 1000" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad6" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f0f9ff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e0f2fe;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1600" height="1000" fill="url(#bgGrad6)"/>
  
  <!-- Title -->
  <text x="800" y="80" font-family="Inter, sans-serif" font-size="48" font-weight="700" fill="#0f172a" text-anchor="middle">Automated Sorting Conveyor</text>
  
  <!-- Conveyor system -->
  <g transform="translate(800, 500)">
    <!-- Conveyor belt -->
    <ellipse cx="-200" cy="0" rx="30" ry="35" fill="none" stroke="#0284c7" stroke-width="10"/>
    <rect x="-200" y="35" width="400" height="80" fill="#38bdf8"/>
    <ellipse cx="200" cy="0" rx="30" ry="35" fill="none" stroke="#0284c7" stroke-width="10"/>
    
    <!-- Moving parts indicator -->
    <path d="M -170 80 L -80 80 M 80 80 L 170 80" stroke="#0ea5e9" stroke-width="6" stroke-dasharray="20,20"/>
    
    <!-- Objects on conveyor -->
    <circle cx="-100" cy="75" r="18" fill="#0284c7"/>
    <circle cx="0" cy="75" r="18" fill="#0284c7"/>
    <circle cx="100" cy="75" r="18" fill="#0284c7"/>
    
    <!-- Vision camera (top) -->
    <rect x="-40" y="-120" width="80" height="60" fill="#0ea5e9" rx="8"/>
    <circle cx="0" cy="-90" r="20" fill="#38bdf8"/>
    <path d="M -30 -80 L 30 -80 L 30 -100 L -30 -100 Z" fill="#e0f2fe" opacity="0.6"/>
    
    <!-- Connection lines -->
    <line x1="0" y1="-60" x2="0" y2="-20" stroke="#0284c7" stroke-width="4"/>
    
    <!-- Actuator arm (right) -->
    <line x1="190" y1="80" x2="240" y2="150" stroke="#0284c7" stroke-width="8" stroke-linecap="round"/>
    <circle cx="240" cy="150" r="15" fill="#0ea5e9"/>
  </g>
  
  <!-- Info boxes -->
  <g font-family="Inter, sans-serif" font-size="32" fill="#475569">
    <text x="200" y="950">Vision-Driven Sorter | Multi-Language | Modular Design</text>
  </g>
</svg>
