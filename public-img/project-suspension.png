<svg viewBox="0 0 1600 1000" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad5" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f0f9ff;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e0f2fe;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1600" height="1000" fill="url(#bgGrad5)"/>
  
  <!-- Title -->
  <text x="800" y="80" font-family="Inter, sans-serif" font-size="48" font-weight="700" fill="#0f172a" text-anchor="middle">FSAE Suspension Upright</text>
  
  <!-- Suspension upright (simplified side view) -->
  <g transform="translate(800, 500)">
    <!-- Main upright body -->
    <path d="M -40 -100 L 40 -100 L 60 0 L 40 100 L -40 100 L -60 0 Z" 
          fill="none" stroke="#0284c7" stroke-width="12" stroke-linejoin="round"/>
    
    <!-- Ball joints -->
    <circle cx="-50" cy="-80" r="20" fill="#38bdf8"/>
    <circle cx="50" cy="-80" r="20" fill="#38bdf8"/>
    <circle cx="-60" cy="0" r="20" fill="#38bdf8"/>
    <circle cx="60" cy="0" r="20" fill="#38bdf8"/>
    <circle cx="-50" cy="80" r="20" fill="#38bdf8"/>
    <circle cx="50" cy="80" r="20" fill="#38bdf8"/>
    
    <!-- Wheel -->
    <circle cx="0" cy="140" r="50" fill="none" stroke="#0284c7" stroke-width="8"/>
    <circle cx="0" cy="140" r="35" fill="none" stroke="#0284c7" stroke-width="4"/>
    
    <!-- Load arrows (acceleration) -->
    <path d="M -100 -120 L -140 -120" stroke="#ea580c" stroke-width="6" marker-end="url(#arrowOrange)"/>
    <text x="-120" y="-110" font-family="Inter" font-size="24" fill="#ea580c" font-weight="600">Cornering Load</text>
  </g>
  
  <!-- Info boxes -->
  <g font-family="Inter, sans-serif" font-size="32" fill="#475569">
    <text x="200" y="950">Lightweight Aluminum | FEA Validated | Competition Ready</text>
  </g>
  
  <defs>
    <marker id="arrowOrange" markerWidth="10" markerHeight="10" refX="5" refY="5" orient="auto">
      <polygon points="0,0 10,5 0,10" fill="#ea580c"/>
    </marker>
  </defs>
</svg>
